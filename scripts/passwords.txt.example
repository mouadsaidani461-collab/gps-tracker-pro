# BFG --replace-text patterns (copy to passwords.txt and edit).
# BFG ignores lines starting with #.
#
# Add one line per LEAKED literal value (from old commits / backups):
#   literal:your-old-admin-password==>REDACTED
#   literal:your-old-64-char-hex-token==>REDACTED
#
# Regex rules below scrub common secret formats across all history
# (including ROADMAP.md, .env, docs, and compose files).

regex:ADMIN_PASSWORD\s*=\s*[^\s#]+==>ADMIN_PASSWORD=REDACTED
regex:TRACCAR_SERVICE_TOKEN\s*=\s*[0-9a-fA-F]{32,}==>TRACCAR_SERVICE_TOKEN=REDACTED
regex:WEB_SERVICE_ACCOUNT_TOKEN\s*=\s*[0-9a-fA-F]{32,}==>WEB_SERVICE_ACCOUNT_TOKEN=REDACTED
regex:--data-urlencode\s+password=[^\s&]+==>--data-urlencode password=REDACTED
regex:"password"\s*:\s*"[^"]{8,}"==>"password":"REDACTED"
regex:BEGIN OPENSSH PRIVATE KEY[\s\S]*?END OPENSSH PRIVATE KEY==>REDACTED
