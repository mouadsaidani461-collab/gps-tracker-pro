# Capture Tracking GPS — Environment Variables Template
# Copy to .env and adjust values before local development or Docker build.
#
# Vite exposes only variables prefixed with VITE_ to the client bundle.
# Rebuild the Docker image after changing build-time variables.

# Application
VITE_APP_NAME=Capture Tracking GPS

# Backend API (Traccar)
# Dev: leave unset or use /api (Vite proxy → localhost:8082)
# Production: full URL e.g. http://your-server:8082/api
VITE_API_BASE_URL=/api

# Map tile provider (optional override)
VITE_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png

# Node environment
NODE_ENV=production

# Docker Hub (optional — used by npm run docker:push)
DOCKERHUB_USERNAME=your-dockerhub-username
