# Capture Tracking GPS — Environment Variables Template
# Copy to .env and adjust values before local development or Docker build.
#
# Vite exposes only variables prefixed with VITE_ to the client bundle.
# Rebuild the Docker image after changing build-time variables.

# Application
VITE_APP_NAME=Capture Tracking GPS

# Backend API (Traccar)
# Dev: leave unset or use /api (Vite proxy → localhost:8082)
# Production: full URL e.g. https://your-domain/api
VITE_API_BASE_URL=/api

# Map tile provider (optional override)
VITE_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png

# Node environment
NODE_ENV=development

# Vite dev: API proxy target (default http://localhost:8082 — Traccar from docker compose up)
# Docker frontend on :3000 (same-origin /api): VITE_DEV_API_TARGET=http://localhost:3000
# VITE_DEV_API_TARGET=http://localhost:8082

# ── Docker / Traccar bootstrap (required for docker compose up) ──
ADMIN_EMAIL=
ADMIN_PASSWORD=
TRACCAR_SERVICE_TOKEN=
FRONTEND_PORT=3000
TRACCAR_HTTP_PORT=8082
GPS_DEVICE_PORT=5024

# Optional MySQL for dev compose (docker compose --profile mysql up)
# Generate: openssl rand -base64 24
# MYSQL_ROOT_PASSWORD=
# MYSQL_HOST=database
# MYSQL_DATABASE=traccar
# MYSQL_USER=traccar
# MYSQL_PASSWORD=

# Docker Hub (optional — used by npm run docker:push)
DOCKERHUB_USERNAME=your-dockerhub-username
