# Capture Tracking GPS — local development / Docker compose template
# Copy: cp .env.example .env  OR  ./scripts/init-dev-env.sh
# Usage: docker compose --env-file .env up -d --build
#
# Never commit .env — it may contain secrets.

# ── Vite (embedded at Docker build time; rebuild image after changes) ──
VITE_APP_NAME="GPS Tracker Pro"
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_API_BASE_URL=/api

# Traccar API (host access when not using Docker network)
TRACCAR_URL=http://localhost:8082

# ── Traccar bootstrap (required for docker compose up) ──
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
TRACCAR_SERVICE_TOKEN=

# ── Ports (optional) ──
FRONTEND_PORT=3000
TRACCAR_HTTP_PORT=8082
GPS_DEVICE_PORT=5024

# Vite dev proxy target (npm run dev — default Traccar on :8082)
# VITE_DEV_API_TARGET=http://localhost:8082
