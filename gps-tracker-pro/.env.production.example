# Capture Tracking GPS — PRODUCTION secrets
# Copy to .env.production and NEVER commit the real file.
#
# Generate strong values:
#   openssl rand -hex 32          # TRACCAR_SERVICE_TOKEN
#   openssl rand -base64 24       # ADMIN_PASSWORD

# ── Domain ──
DOMAIN=gps-tracker-pro.ma
CERTBOT_EMAIL=mouadsaidani461@gmail.com

# Edge nginx config (default edge.local.conf = HTTP-only until SSL exists)
# After ./scripts/deploy-production.sh init: EDGE_NGINX_CONF=./docker/nginx/edge.conf
# EDGE_NGINX_CONF=./docker/nginx/edge.conf

# ── Build ──
VITE_APP_NAME=Capture Tracking GPS
VITE_API_BASE_URL=/api
VITE_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png
IMAGE_TAG=latest

# ── Traccar admin (rotate from defaults — NEVER use admin123) ──
ADMIN_EMAIL=you@yourcompany.ma
ADMIN_PASSWORD=REDACTED
ADMIN_NAME=Admin

# ── Traccar service account (rotate from capture-bootstrap-change-me) ──
TRACCAR_SERVICE_TOKEN=CHANGE_ME_use_openssl_rand_hex_32

# ── GPS device port (optional public bind) ──
# Leave as 127.0.0.1:5023 if using a separate GPS gateway; use 5023:5023 for direct device access
GPS_PUBLIC_PORT=127.0.0.1:5023
