# Capture Tracking GPS — PRODUCTION template
# Copy: cp .env.production.example .env.production
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# Generate secrets (placeholders below — replace before deploy):
#   openssl rand -hex 32          # TRACCAR_SERVICE_TOKEN
#   openssl rand -base64 24       # ADMIN_PASSWORD (min 12 chars)
#   openssl rand -base64 24       # POSTGRES_PASSWORD

# ── Domain & SSL ──
DOMAIN=gps-tracker-pro.ma
CERTBOT_EMAIL=admin@your-domain.com

# Edge nginx (HTTP-only until SSL init)
# After ./scripts/deploy-production.sh init:
# EDGE_NGINX_CONF=./docker/nginx/edge.conf

# ── Hetzner DNS API (init creates A records) ──
# Store token in GitHub Secrets: HETZNER_DNS_API_TOKEN
# HETZNER_DNS_API_TOKEN=
# HETZNER_DNS_ZONE_ID=          # optional — auto-detected from DOMAIN
# HETZNER_DNS_ZONE_NAME=gps-tracker-pro.ma
# HETZNER_SERVER_IP=            # optional — auto-detected on server

# ── Vite build (passed as docker build --build-arg) ──
VITE_APP_NAME="GPS Tracker Pro"
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_API_BASE_URL=/api
IMAGE_TAG=latest

# Traccar (internal Docker network — documented for scripts)
TRACCAR_URL=http://traccar:8082

# ── PostgreSQL (password never in docker-compose — env only) ──
POSTGRES_DB=traccar
POSTGRES_USER=traccar
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_base64_24

# ── Traccar admin (rotate — never use defaults in production) ──
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_ME_use_openssl_rand_base64_24
ADMIN_NAME=Admin
TRACCAR_SERVICE_TOKEN=CHANGE_ME_use_openssl_rand_hex_32

# ── GPS device port (optional public bind) ──
GPS_PUBLIC_PORT=127.0.0.1:5023

# ── Backups (scripts/backup.sh) ──
# BACKUP_DIR=/var/backups/capture-gps
# BACKUP_RETENTION_DAYS=7
# AGE_PUBLIC_KEY=age1...           # preferred encryption
# BACKUP_GPG_RECIPIENT=you@domain.com
# RCLONE_REMOTE=b2:capture-gps-backups
# AWS_S3_BUCKET=s3://your-bucket/capture-gps

# ── Monitoring alerts (scripts/monitor.sh) ──
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# ALERT_EMAIL_TO=ops@your-domain.com
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.your-domain.com
# SENDGRID_API_KEY=
