{
  "name": "gps-tracker-pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/check-traccar.mjs && vite",
    "dev:skip-check": "vite",
    "docker:backend": "docker compose up -d traccar traccar-init",
    "docker:init": "./scripts/init-dev-env.sh",
    "docker:up": "./scripts/init-dev-env.sh && ./scripts/validate-env.sh .env docker && docker compose --env-file .env up -d --build",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "playwright:install": "playwright install chromium",
    "pretest:e2e": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "preview": "vite preview",
    "generate:icons": "node scripts/generate-icons.mjs",
    "docker:build": "docker build -t gps-tracker-pro:latest .",
    "docker:push": "docker push YOUR_DOCKERHUB_USERNAME/gps-tracker-pro:latest"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "otpauth": "^9.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.2",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.0.0",
    "msw": "^2.14.6",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "dompurify": "^3.4.11",
    "uuid": "^11.1.1"
  }
}
