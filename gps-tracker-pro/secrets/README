# Optional file-based secrets (gitignored). Alternative to storing values in .env.production.
# Copy examples, fill real values, chmod 600:
#   cp secrets/traccar_service_token.example secrets/traccar_service_token
#   cp secrets/admin_password.example secrets/admin_password
#   cp secrets/postgres_password.example secrets/postgres_password
#   cp secrets/certbot_email.example secrets/certbot_email
#   cp secrets/hetzner_dns_api_token.example secrets/hetzner_dns_api_token
#
# deploy-production.sh loads these files automatically when present (overrides .env.production).
