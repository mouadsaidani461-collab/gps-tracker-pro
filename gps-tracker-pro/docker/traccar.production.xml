<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE properties SYSTEM 'http://java.sun.com/dtd/properties.dtd'>
<properties>

    <!-- Production Traccar config — API only via nginx /api proxy -->

    <entry key='database.driver'>org.h2.Driver</entry>
    <entry key='database.url'>jdbc:h2:./data/database</entry>
    <entry key='database.user'>sa</entry>
    <entry key='database.password' />

    <!-- Admin bootstrap uses service token — never open public registration -->
    <entry key='web.registration'>false</entry>

    <!-- Bind HTTP on all interfaces inside Docker network only -->
    <entry key='web.port'>8082</entry>

</properties>
